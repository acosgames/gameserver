{
    "name": "gameserver",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "concurrently -n tsc,node \"npm:build:watch\" \"npm:start:watch\"",
        "build": "tsc -p tsconfig.json",
        "build:watch": "tsc -p tsconfig.json --noCheck --watch --preserveWatchOutput",
        "start:watch": "node --inspect=9944 --watch --enable-source-maps --watch-preserve-output dist/index.js",
        "dev": "pm2 start dist/index.js --name gameserver --node-args=\"--inspect=10003\" --watch \"dist ../shared\" --ignore-watch \"./serverScripts package.json node_modules\"",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "dependencies": {
        "@acosgames/framework": "^1.0.8",
        "acos-json-delta": "^1.0.4",
        "acos-json-encoder": "^2.0.15",
        "axios": "^1.7.9",
        "isolated-vm": "^6.0.2",
        "node-cache": "^5.1.2",
        "openskill": "^1.4.1",
        "priorityqueuejs": "^2.0.0",
        "queue-fifo": "^0.2.6",
        "redis-sorted-set": "^2.0.0",
        "seedrandom": "^3.0.5",
        "shared": "file:../shared",
        "websocket": "^1.0.33"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^20.19.39",
        "typescript": "^5.9.3"
    }
}
